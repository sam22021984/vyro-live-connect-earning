{
  "name": "AiOrchestratorLog",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "conversation_id": {
      "type": "string"
    },
    "request": {
      "type": "string"
    },
    "tool_used": {
      "type": "string"
    },
    "routing_explanation": {
      "type": "string"
    },
    "result": {
      "type": "object"
    }
  },
  "required": [
    "user_id",
    "conversation_id",
    "request",
    "tool_used"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}