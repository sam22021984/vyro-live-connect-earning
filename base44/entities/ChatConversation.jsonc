{
  "name": "ChatConversation",
  "type": "object",
  "properties": {
    "participant_name": {
      "type": "string"
    },
    "participant_avatar": {
      "type": "string"
    },
    "participant_id": {
      "type": "string"
    },
    "is_vip": {
      "type": "boolean",
      "default": false
    },
    "vip_badge": {
      "type": "string"
    },
    "is_online": {
      "type": "boolean",
      "default": false
    },
    "last_seen": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_time": {
      "type": "string"
    },
    "last_message_date": {
      "type": "string"
    },
    "unread_count": {
      "type": "number",
      "default": 0
    },
    "is_pinned": {
      "type": "boolean",
      "default": false
    },
    "is_muted": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "participant_name"
  ]
}